generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  domains   Domain[]
  lists     LeadList[]
  leads     Lead[]
  templates Template[]
  campaigns     Campaign[]
  emailLogs     EmailLog[]
  inboxMessages InboxMessage[]
  erpnextSettings ERPNextSettings?
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  name           String?
  email          String       @unique
  passwordHash   String?
  role           Role         @default(USER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SALES_USER
  VIEWER
  USER
}

model Domain {
  id               String       @id @default(cuid())
  organizationId   String
  domainName       String       @unique
  spfStatus        String       @default("PENDING")
  dkimStatus       String       @default("PENDING")
  dmarcStatus      String       @default("PENDING")
  mxStatus         String       @default("PENDING")
  sslStatus        String       @default("PENDING")
  blacklistStatus  String       @default("CLEAN")
  healthScore      Int          @default(100)
  sendingStatus    String       @default("SAFE")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mailboxes        Mailbox[]
}

model Mailbox {
  id               String   @id @default(cuid())
  domainId         String
  email            String   @unique
  displayName      String?
  smtpHost         String?
  smtpPort         Int?
  imapHost         String?
  imapPort         Int?
  password         String?
  dailyLimit       Int      @default(10)
  hourlyLimit      Int      @default(2)
  cooldownSeconds  Int      @default(120)
  status           String   @default("ACTIVE")
  signature        String?  @db.Text
  lastSentAt       DateTime?
  lastSyncedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  domain           Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  campaigns        Campaign[]
  inboxMessages    InboxMessage[]
}

model LeadList {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads          Lead[]
  campaigns      Campaign[]
}

model Lead {
  id               String   @id @default(cuid())
  organizationId   String
  listId           String?
  firstName        String?
  lastName         String?
  businessName     String?
  email            String
  phone            String?
  website          String?
  industry         String?
  city             String?
  country          String?
  source           String   @default("MANUAL") // MANUAL, CSV, ERPNEXT
  erpnextId        String?  // ERPNext document name
  erpnextType      String?  // 'Lead' or 'Contact'
  status           String   @default("NEW") // NEW, CONTACTED, REPLIED, BOUNCED, UNSUBSCRIBED
  verificationStatus String @default("UNVERIFIED") // UNVERIFIED, VALID, INVALID
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  list             LeadList?    @relation(fields: [listId], references: [id], onDelete: SetNull)
  emailLogs        EmailLog[]
  inboxMessages    InboxMessage[]

  @@unique([organizationId, email])
}

model Template {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  category       String?  // e.g., Real Estate, Healthcare
  subject        String
  body           String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns      Campaign[]
}

model Campaign {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  listId         String
  templateId     String
  mailboxId      String
  status         String   @default("DRAFT") // DRAFT, SCHEDULED, RUNNING, PAUSED, COMPLETED
  scheduledAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  list           LeadList     @relation(fields: [listId], references: [id], onDelete: Restrict)
  template       Template     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  mailbox        Mailbox      @relation(fields: [mailboxId], references: [id], onDelete: Restrict)
  emailLogs      EmailLog[]
}

model EmailLog {
  id             String   @id @default(cuid())
  organizationId String
  campaignId     String?
  leadId         String
  subject        String
  body           String   @db.Text
  status         String   @default("QUEUED") // QUEUED, SENT, FAILED, BOUNCED, OPENED, REPLIED
  messageId      String?  // SMTP Message ID
  error          String?  @db.Text
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign       Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model InboxMessage {
  id             String   @id @default(cuid())
  organizationId String
  mailboxId      String
  leadId         String?
  fromEmail      String
  subject        String
  body           String   @db.Text
  isRead         Boolean  @default(false)
  receivedAt     DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mailbox        Mailbox      @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model ERPNextSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  url            String
  apiKey         String
  apiSecret      String
  autoSyncLeads  Boolean  @default(true)
  autoSyncContacts Boolean @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
